# Non-secret development placeholder file.
# Production values live in /etc/soruyorum/portal-api.env and are loaded by docker compose.

POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
DATABASE_URL=postgresql://app_user:sUH7NRIozvpkCqQ4MGkbKYW2M9QX-U_W7ZVCDTq6HPGcicvEExK9@195.201.108.52:5432/app_db
REDIS_URL=redis://:113041122839sS?!_@195.201.108.52:6379
