# soruyorum.online (ayri repo) runtime env
# Not: JWT_SECRET'i prod icin mutlaka degistirin.
POSTGRES_PASSWORD=postgres
JWT_SECRET=super-secret-dev-key

# --- SMS / Phone OTP ---
# To enable real SMS sending, set provider to netgsm and fill credentials.
SMS_PROVIDER=netgsm
NETGSM_USERNAME=2886060760
NETGSM_PASSWORD=49F4,4F
NETGSM_SENDER=KEYPADSISTE
# NETGSM_ENDPOINT=https://api.netgsm.com.tr/sms/send/get

# Optional OTP settings
# PHONE_OTP_SECRET=CHANGE_ME_STRONG (if omitted, JWT_SECRET is used)
PHONE_OTP_TTL_SECONDS=300
PHONE_OTP_MAX_SENDS_PER_HOUR=5
PHONE_OTP_MESSAGE_TEMPLATE=Doğrulama kodunuz: {{code}}\nBu kodu kimseyle paylaşmayınız.

# Portal (build-time)
NEXT_PUBLIC_ENABLED_EVENT_TYPES=quiz
NEXT_PUBLIC_SITE_VARIANT=soruyorum
