EMAIL_TOKEN_SECRET=change_me_long_random_email_token_secret
PHONE_OTP_SECRET=change_me_long_random_phone_otp_secret

# Portal (build-time/public)
NEXT_PUBLIC_ENABLED_EVENT_TYPES=quiz
NEXT_PUBLIC_SITE_VARIANT=soruyorum
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_UPGRADE_CONTACT_EMAIL=info@soruyorum.online
NEXT_PUBLIC_UPGRADE_CONTACT_PHONE=+90 (532) 222-8040
NEXT_PUBLIC_UPGRADE_CONTACT_PHONES=+90 (532) 222-8040 | +90 (212) 503-3939
NEXT_PUBLIC_UPGRADE_CONTACT_ADDRESS=Istanbul, Kavacik Mh., Fatih Sultan Mehmet Cd. Tonoglu Plaza No:3 Kat:4, Beykoz/Istanbul
PUBLIC_PLANS_ENABLED=false

# Email verification
ENFORCE_EMAIL_VERIFICATION=false
ENFORCE_EMAIL_VERIFICATION_FROM=2026-02-05T00:00:00Z
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Runtime URLs
PORTAL_BASE_URL=https://soruyorum.online
FRONTEND_URL=https://soruyorum.online
DOMAIN_SYSTEM_BASE=soruyorum.live
DOMAIN_CONNECT_TARGET=connect.soruyorum.live
LEGACY_JOIN_BASE_URL=https://mobil.soruyorum.online

# Mail
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_password
MAIL_FROM=no-reply@soruyorum.online
MAIL_FROM_NAME=Soruyorum
PAYMENT_NOTIFICATION_EMAIL=odeme@soruyorum.online
MAIL_LOGO_URL=https://soruyorum.online/images/mail-logo-20260325.png

# SMS
SMS_PROVIDER=test
NETGSM_USERNAME=your_usercode
NETGSM_PASSWORD=your_password
NETGSM_SENDER=your_sender_header
NETGSM_ENDPOINT=https://api.netgsm.com.tr/sms/send/get
PHONE_OTP_TTL_SECONDS=300
PHONE_OTP_MAX_SENDS_PER_HOUR=5
PHONE_OTP_MESSAGE_TEMPLATE=Dogrulama kodunuz: {{code}}\nBu kodu kimseyle paylasmayiniz.

# Cloudflare
CLOUDFLARE_SAAS_ZONE_ID=
CLOUDFLARE_SAAS_API_TOKEN=

# PayTR
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt
PAYTR_OK_URL=https://soruyorum.online/dashboard/billing/success
PAYTR_FAIL_URL=https://soruyorum.online/dashboard/billing/fail
PAYTR_PREMIUM_AMOUNT=500000
PAYTR_PREMIUM_CURRENCY=TRY
PAYTR_TEST_MODE=1
PAYTR_LANG=tr
PAYTR_DEBUG_ON=0
PAYTR_TIMEOUT_LIMIT=30
PAYTR_DEFAULT_ADDRESS=Turkiye
PAYTR_GET_TOKEN_URL=https://www.paytr.com/odeme/api/get-token
PAYTR_IFRAME_BASE_URL=https://www.paytr.com/odeme/guvenli/
PAYTR_EFT_ENABLED=0
PAYTR_EFT_IFRAME_BASE_URL=https://www.paytr.com/odeme/api/

# Manual bank transfer
BANK_TRANSFER_ENABLED=1
BANK_TRANSFER_ACCOUNTS_JSON=[{"id":"garanti","bankName":"Garanti BBVA","accountHolder":"Sirket Unvani","iban":"TR000000000000000000000000","branchName":"Main Branch","branchCode":"000","swiftCode":null}]
BANK_TRANSFER_ACCOUNT_HOLDER=
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BANK_NAME=Garanti BBVA
BANK_TRANSFER_BRANCH_NAME=
BANK_TRANSFER_BRANCH_CODE=
BANK_TRANSFER_SWIFT_CODE=
BANK_TRANSFER_PAYMENT_WINDOW_HOURS=48

# Auth cookie / CSRF / CSP
AUTH_COOKIE_NAME=__Host-soruyorum_auth
AUTH_COOKIE_MAX_AGE_SECONDS=604800
AUTH_COOKIE_SAME_SITE=lax
CSRF_ALLOWED_ORIGINS=https://soruyorum.online,https://www.soruyorum.online
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/api/security/csp-report
