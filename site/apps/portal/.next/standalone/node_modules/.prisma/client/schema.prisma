generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activities {
  id             String           @id
  event_id       String
  type           String
  name           String?
  order_index    Int
  duration       Int?
  config         Json?
  status         String           @default("pending")
  started_at     DateTime?
  ended_at       DateTime?
  created_at     DateTime         @default(now())
  events         events           @relation(fields: [event_id], references: [id], onDelete: Cascade)
  bingo_sessions bingo_sessions[]
  questions      questions[]
  responses      responses[]
  scores         scores[]

  @@index([event_id])
}

model audit_logs {
  id              String        @id
  organization_id String
  user_id         String?
  action          String
  resource        String
  resource_id     String?
  details         Json?
  ip_address      String?
  user_agent      String?
  created_at      DateTime      @default(now())
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users           users?        @relation(fields: [user_id], references: [id])

  @@index([organization_id, action])
  @@index([organization_id, created_at])
  @@index([organization_id])
}

model bingo_cards {
  id             String          @id
  session_id     String
  participant_id String
  card_number    Int
  numbers        Json
  marked_numbers Json?           @default("[]")
  qr_code        String?
  pdf_url        String?
  created_at     DateTime        @default(now())
  participants   participants    @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  bingo_sessions bingo_sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade)
  bingo_winners  bingo_winners[]
}

model bingo_sessions {
  id            String          @id
  activity_id   String
  type          String?         @default("classic")
  number_range  Json?           @default("[1, 90]")
  drawn_numbers Json?           @default("[]")
  status        String?         @default("waiting")
  created_at    DateTime        @default(now())
  bingo_cards   bingo_cards[]
  activities    activities      @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  bingo_winners bingo_winners[]
}

model bingo_winners {
  id             String         @id
  session_id     String
  participant_id String?
  card_id        String?
  win_type       String?
  verified       Boolean        @default(false)
  prize          String?
  declared_at    DateTime       @default(now())
  bingo_cards    bingo_cards?   @relation(fields: [card_id], references: [id])
  participants   participants?  @relation(fields: [participant_id], references: [id])
  bingo_sessions bingo_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model events {
  id                String              @id
  organization_id   String?
  name              String
  slug              String?
  description       String?
  start_time        DateTime?
  end_time          DateTime?
  duration          Int?
  access_type       String              @default("pin")
  pin               String?
  event_code        String?             @unique
  event_pin         String?             @unique
  qr_code_url       String?
  join_url          String?
  event_type        String              @default("quiz")
  max_participants  Int?                @default(100)
  status            String              @default("draft")
  branding          Json?
  settings          Json?
  created_by        String?
  created_at        DateTime            @default(now())
  updated_at        DateTime
  activities        activities[]
  users             users?              @relation(fields: [created_by], references: [id])
  organizations     organizations?      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  participants      participants[]
  qanda_submissions qanda_submissions[]
  reports           reports[]

  @@index([event_code])
  @@index([event_pin])
  @@index([organization_id])
  @@index([status])
}

model organizations {
  id            String          @id
  name          String
  slug          String?         @unique
  plan          String          @default("free")
  logo_url      String?
  branding      Json?
  settings      Json?
  created_at    DateTime        @default(now())
  updated_at    DateTime
  audit_logs    audit_logs[]
  events        events[]
  subscriptions subscriptions[]
  users         users[]
}

model participants {
  id                String              @id
  event_id          String
  user_id           String?
  name              String
  email             String?
  phone             String?
  device_type       String?
  device_id         String?
  fingerprint       String?
  metadata          Json?
  joined_at         DateTime            @default(now())
  left_at           DateTime?
  last_seen_at      DateTime?
  bingo_cards       bingo_cards[]
  bingo_winners     bingo_winners[]
  events            events              @relation(fields: [event_id], references: [id], onDelete: Cascade)
  qanda_submissions qanda_submissions[]
  responses         responses[]
  scores            scores[]

  @@index([event_id])
}

model qanda_submissions {
  id               String        @id
  event_id         String
  participant_id   String?
  participant_name String?
  question_text    String
  status           String        @default("pending")
  is_answered      Boolean       @default(false)
  created_at       DateTime      @default(now())
  updated_at       DateTime
  events           events        @relation(fields: [event_id], references: [id], onDelete: Cascade)
  participants     participants? @relation(fields: [participant_id], references: [id])

  @@index([event_id])
  @@index([status])
}

model questions {
  id             String      @id
  activity_id    String
  type           String
  text           String
  image_url      String?
  options        Json?
  correct_answer Json?
  time_limit     Int         @default(30)
  points         Int         @default(10)
  order_index    Int
  created_at     DateTime    @default(now())
  activities     activities  @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  responses      responses[]
}

model reports {
  id           String   @id
  event_id     String
  type         String?
  format       String?
  data         Json?
  file_url     String?
  generated_at DateTime @default(now())
  events       events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

model responses {
  id             String       @id
  participant_id String
  question_id    String
  activity_id    String?
  answer         Json?
  is_correct     Boolean?
  response_time  Int?
  points         Int?
  created_at     DateTime     @default(now())
  activities     activities?  @relation(fields: [activity_id], references: [id])
  participants   participants @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  questions      questions    @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@index([participant_id])
  @@index([question_id])
}

model scores {
  id                String       @id
  participant_id    String
  activity_id       String
  total_points      Int          @default(0)
  correct_answers   Int          @default(0)
  wrong_answers     Int          @default(0)
  avg_response_time Int?
  rank              Int?
  updated_at        DateTime
  activities        activities   @relation(fields: [activity_id], references: [id], onDelete: Cascade)
  participants      participants @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@index([activity_id])
}

model sessions {
  id         String   @id
  user_id    String
  expires_at DateTime
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                   String        @id
  organization_id      String
  plan                 String
  status               String?       @default("active")
  current_period_start DateTime?     @db.Date
  current_period_end   DateTime?     @db.Date
  payment_method       String?
  metadata             Json?
  created_at           DateTime      @default(now())
  updated_at           DateTime
  organizations        organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model users {
  id                  String         @id
  email               String         @unique
  password_hash       String?
  name                String?
  avatar_url          String?
  phone               String?
  phone_verified      Boolean        @default(false)
  phone_verified_at   DateTime?
  role                String         @default("organizer")
  organization_id     String?
  email_verified      Boolean        @default(false)
  created_at          DateTime       @default(now())
  updated_at          DateTime
  company             String?
  date_format         String         @default("dd/mm/yyyy")
  email_notifications Boolean        @default(true)
  font_size           String         @default("medium")
  language            String         @default("tr")
  push_notifications  Boolean        @default(false)
  region              String         @default("TR")
  sms_notifications   Boolean        @default(false)
  theme               String         @default("light")
  timezone            String?        @default("Europe/Istanbul")
  two_factor_enabled  Boolean        @default(false)
  two_factor_secret   String?
  audit_logs          audit_logs[]
  events              events[]
  sessions            sessions[]
  organizations       organizations? @relation(fields: [organization_id], references: [id])
}
