# Example environment file (DO NOT put real secrets in git)

# Required for local/prod compose
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_me_long_random

# Optional: Portal build args
NEXT_PUBLIC_ENABLED_EVENT_TYPES=quiz
NEXT_PUBLIC_SITE_VARIANT=default

# Optional: Premium / Billing UI
# Shown on /dashboard/billing (client-side)
NEXT_PUBLIC_PREMIUM_PRICE_LABEL=120 USD

# --- SMS / Phone OTP ---
# Default is test mode (no SMS is sent). Set to netgsm to enable real sending.
SMS_PROVIDER=test

# NetGSM settings (required only when SMS_PROVIDER=netgsm)
NETGSM_USERNAME=your_usercode
NETGSM_PASSWORD=your_password
NETGSM_SENDER=your_sender_header
# Optional override
NETGSM_ENDPOINT=https://api.netgsm.com.tr/sms/send/get

# OTP settings
# If omitted, API falls back to JWT_SECRET.
PHONE_OTP_SECRET=optional_but_recommended
PHONE_OTP_TTL_SECONDS=300
PHONE_OTP_MAX_SENDS_PER_HOUR=5
# Use {{code}} placeholder
PHONE_OTP_MESSAGE_TEMPLATE=Doğrulama kodunuz: {{code}}\nBu kodu kimseyle paylaşmayınız.

# --- PayTR (Premium upgrade) ---
# NOTE: Keep these secrets out of git.
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt

# Redirect URLs (user landing pages)
PAYTR_OK_URL=https://soruyorum.online/dashboard/billing/success
PAYTR_FAIL_URL=https://soruyorum.online/dashboard/billing/fail

# Amount in kurus (TRY) or cents (USD/EUR) depending on PayTR currency
# Example: 5000 TL => 500000
PAYTR_PREMIUM_AMOUNT=500000
PAYTR_PREMIUM_CURRENCY=TRY

# 1 = test mode, 0 = live
PAYTR_TEST_MODE=1

PAYTR_LANG=tr
PAYTR_DEBUG_ON=0
PAYTR_TIMEOUT_LIMIT=30
PAYTR_DEFAULT_ADDRESS=Türkiye

# Advanced overrides (usually not needed)
PAYTR_GET_TOKEN_URL=https://www.paytr.com/odeme/api/get-token
PAYTR_IFRAME_BASE_URL=https://www.paytr.com/odeme/guvenli/
