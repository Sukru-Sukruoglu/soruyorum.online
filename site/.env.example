# Example environment file (DO NOT put real secrets in git)

# Required for local/prod compose
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
JWT_SECRET=change_me_long_random
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/soruyorum_dev?schema=public
REDIS_URL=redis://:change_me@127.0.0.1:6379

# Optional: Portal build args
NEXT_PUBLIC_ENABLED_EVENT_TYPES=quiz
NEXT_PUBLIC_SITE_VARIANT=default
NEXT_PUBLIC_DEMO_MODE=false

# Spring pilot campaign (optional)
# Manual pilot plan code for verified companies.
SPRING_PILOT_PLAN=spring_pilot_500
SPRING_PILOT_START=2026-04-01T00:00:00+03:00
SPRING_PILOT_END=2026-05-31T23:59:59+03:00
# Keep enabled for pre-launch setup/testing; set to 0 to enforce the start date strictly.
SPRING_PILOT_ALLOW_EARLY_ACCESS=1

# Optional: Premium / Billing UI
# Shown on /dashboard/billing (client-side)
NEXT_PUBLIC_PREMIUM_PRICE_LABEL=120 USD

# Upgrade contact (optional)
# Sidebar "Premium'a Geç" -> "Yükselt" opens these contact details.
NEXT_PUBLIC_UPGRADE_CONTACT_EMAIL=bilgi@keypadsistem.com
NEXT_PUBLIC_UPGRADE_CONTACT_PHONE=+90 212 503 39 39
NEXT_PUBLIC_UPGRADE_CONTACT_PHONES=+90 (532) 222-8040 | +90 (212) 503-3939
NEXT_PUBLIC_UPGRADE_CONTACT_ADDRESS=Kavacık, Fatih Sultan Mehmet Cd. Tonoğlu Plaza No:3 Kat:4, 34810 Beykoz/İstanbul

# Public plans page (optional)
# /plans route exists, but returns 404 unless this is true.
PUBLIC_PLANS_ENABLED=false

# Private pricing preview page (optional)
# /plans-preview requires ?preview=<token> and is always noindex.
PRICING_PREVIEW_TOKEN=change_me_preview_token

# --- Email verification (optional) ---
# If enabled, users created on/after ENFORCE_EMAIL_VERIFICATION_FROM must verify email before login.
# Set to true/1/yes to enable.
ENFORCE_EMAIL_VERIFICATION=false
# ISO date-time; example uses Feb 5, 2026
ENFORCE_EMAIL_VERIFICATION_FROM=2026-02-05T00:00:00Z
# Verification token lifetime
EMAIL_VERIFICATION_EXPIRES_IN=24h
# Use a separate random secret instead of reusing JWT_SECRET.
EMAIL_TOKEN_SECRET=change_me_long_random_email_token_secret
# Public base URL for links in emails (portal runs under the main domain)
PORTAL_BASE_URL=https://soruyorum.online

# --- White-label domain routing ---
# Sistem subdomainleri bu kök domain altında üretilir. Örn: firma.soruyorum.live
DOMAIN_SYSTEM_BASE=soruyorum.live
# Müşteri CNAME kayıtları bu hedefe yönlenir. Örn: event.firma.com -> connect.soruyorum.live
DOMAIN_CONNECT_TARGET=connect.soruyorum.live
# Legacy brand join adresi (custom domain kapalı organizasyonlar için)
LEGACY_JOIN_BASE_URL=https://mobil.soruyorum.online
# Cloudflare for SaaS
# Control zone: soruyorum.live
# Scoped API token kullanın, global key kullanmayın.
# Minimum gereken yetki:
# - SSL and Certificates: Write
CLOUDFLARE_SAAS_ZONE_ID=
CLOUDFLARE_SAAS_API_TOKEN=

# Mail provider
# - smtp: Use Nodemailer SMTP (requires outbound SMTP reachability)
# - brevo: Use Brevo HTTP API over HTTPS (recommended when SMTP ports are blocked)
MAIL_PROVIDER=smtp

# SMTP settings (required when MAIL_PROVIDER=smtp and ENFORCE_EMAIL_VERIFICATION=true)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_password
MAIL_FROM=no-reply@soruyorum.online

# Brevo settings (required when MAIL_PROVIDER=brevo and ENFORCE_EMAIL_VERIFICATION=true)
BREVO_API_KEY=your_brevo_api_key
# Optional display name
MAIL_FROM_NAME=Soruyorum

# --- SMS / Phone OTP ---
# Default is test mode (no SMS is sent). Set to netgsm to enable real sending.
SMS_PROVIDER=test

# NetGSM settings (required only when SMS_PROVIDER=netgsm)
NETGSM_USERNAME=your_usercode
NETGSM_PASSWORD=your_password
NETGSM_SENDER=your_sender_header
# Optional override
NETGSM_ENDPOINT=https://api.netgsm.com.tr/sms/send/get

# OTP settings
# Use a dedicated random secret in production.
PHONE_OTP_SECRET=change_me_long_random_phone_otp_secret
PHONE_OTP_TTL_SECONDS=300
PHONE_OTP_MAX_SENDS_PER_HOUR=5
# Use {{code}} placeholder
PHONE_OTP_MESSAGE_TEMPLATE=Doğrulama kodunuz: {{code}}\nBu kodu kimseyle paylaşmayınız.

# --- PayTR (Premium upgrade) ---
# NOTE: Keep these secrets out of git.
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt

# Redirect URLs (user landing pages)
PAYTR_OK_URL=https://soruyorum.online/dashboard/billing/success
PAYTR_FAIL_URL=https://soruyorum.online/dashboard/billing/fail

# Amount in kurus (TRY) or cents (USD/EUR) depending on PayTR currency
# Example: 5000 TL => 500000
PAYTR_PREMIUM_AMOUNT=500000
PAYTR_PREMIUM_CURRENCY=TRY

# 1 = test mode, 0 = live
PAYTR_TEST_MODE=1

PAYTR_LANG=tr
PAYTR_DEBUG_ON=0
PAYTR_TIMEOUT_LIMIT=30
PAYTR_DEFAULT_ADDRESS=Türkiye

# Advanced overrides (usually not needed)
PAYTR_GET_TOKEN_URL=https://www.paytr.com/odeme/api/get-token
PAYTR_IFRAME_BASE_URL=https://www.paytr.com/odeme/guvenli/
PAYTR_EFT_ENABLED=0
PAYTR_EFT_IFRAME_BASE_URL=https://www.paytr.com/odeme/api/

# --- Manual Bank Transfer (optional) ---
# Used by the custom Havale / EFT notification flow.
BANK_TRANSFER_ENABLED=1
BANK_TRANSFER_ACCOUNTS_JSON=[{"id":"garanti","bankName":"Garanti BBVA","accountHolder":"Sirket Unvani","iban":"TR000000000000000000000000","branchName":"Main Branch","branchCode":"000","swiftCode":null}]
BANK_TRANSFER_ACCOUNT_HOLDER=Soruyorum Online
BANK_TRANSFER_IBAN=TR000000000000000000000000
BANK_TRANSFER_BANK_NAME=Example Bank
BANK_TRANSFER_BRANCH_NAME=Main Branch
BANK_TRANSFER_BRANCH_CODE=0000
BANK_TRANSFER_SWIFT_CODE=
BANK_TRANSFER_PAYMENT_WINDOW_HOURS=48

# Payment notifications
PAYMENT_NOTIFICATION_EMAIL=odeme@soruyorum.online

# Auth cookie / CSRF / CSP
AUTH_COOKIE_NAME=__Host-soruyorum_auth
AUTH_COOKIE_MAX_AGE_SECONDS=604800
AUTH_COOKIE_SAME_SITE=lax
CSRF_ALLOWED_ORIGINS=https://soruyorum.online,https://www.soruyorum.online
CSP_REPORT_ONLY=true
CSP_REPORT_URI=/api/security/csp-report
